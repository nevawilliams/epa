# After a punt - what EP does opponent get from where they receive it?
punt_ep <- pbp_states |>
filter(punt_attempt == 1, !is.na(kick_distance)) |>
mutate(
opponent_yardline = 100 - (yardline_100 - kick_distance),
opponent_yardline = pmax(pmin(opponent_yardline, 99), 1)
) |>
summarise(avg_opponent_yardline = mean(opponent_yardline, na.rm = TRUE))
# After a turnover - where does opponent get the ball?
turnover_ep <- pbp_states |>
filter(interception == 1 | fumble_lost == 1) |>
summarise(avg_yardline = mean(yardline_100, na.rm = TRUE))
# After a missed FG - opponent gets ball at spot
fg_miss_ep <- pbp_states |>
filter(field_goal_result %in% c("missed", "blocked")) |>
summarise(avg_yardline = mean(yardline_100, na.rm = TRUE))
tibble(
event = c("punt", "turnover", "fg_miss"),
avg_yardline = c(
punt_ep$avg_opponent_yardline,
turnover_ep$avg_yardline,
fg_miss_ep$avg_yardline
)
