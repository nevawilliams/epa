library(nflreadr)
library(tidyverse)
pbp <- load_pbp(2022:2025)  # just 3 years to start, faster
# 2025 Chargers 2nd & short vs league average
second_short <- pbp |>
filter(
season == 2025,
season_type == "REG",
down == 2,
ydstogo <= 3,
play_type %in% c("run", "pass"),
!is.na(epa)
) |>
mutate(
is_chargers = if_else(posteam == "LAC", "Chargers", "League Average")
)
# Plot
ggplot(second_short, aes(x = play_type, y = epa, fill = is_chargers)) +
geom_boxplot(alpha = 0.7) +
facet_wrap(~is_chargers) +
scale_fill_manual(values = c("Chargers" = "#0080C6",
"League Average" = "#FFB81C")) +
labs(
title = "2nd & Short EPA: Chargers vs League Average (2025)",
subtitle = "Run vs Pass | Regular Season",
x = "Play Type",
y = "EPA",
caption = "Data: nflfastR"
) +
theme_minimal() +
theme(legend.position = "none")
second_short <- pbp |>
filter(
season == 2024,
season_type == "REG",
down == 2,
ydstogo <= 3,
play_type %in% c("run", "pass"),
!is.na(epa)
) |>
mutate(
is_chargers = if_else(posteam == "LAC", "Chargers", "Rest of NFL"),
converted = if_else(first_down == 1, 1, 0)
)
# Conversion rate by play type
second_short |>
group_by(is_chargers, play_type) |>
summarise(
n = n(),
conversion_rate = mean(converted),
mean_epa = mean(epa)
) |>
ggplot(aes(x = play_type, y = conversion_rate, fill = is_chargers)) +
geom_col(position = "dodge", alpha = 0.85) +
scale_fill_manual(values = c("Chargers" = "#0080C6",
"Rest of NFL" = "#888888")) +
labs(
title = "2nd & Short Conversion Rate: Chargers vs NFL (2024)",
subtitle = "Did the Chargers leave value on the table?",
x = "Play Type",
y = "Conversion Rate",
fill = ""
) +
theme_minimal()
second_short |>
group_by(is_chargers, play_type) |>
summarise(
n = n(),
conversion_rate = mean(converted),
mean_epa = mean(epa),
.groups = "drop"
) |>
ggplot(aes(x = play_type, y = conversion_rate, fill = is_chargers)) +
geom_col(position = "dodge", alpha = 0.85) +
geom_text(aes(label = paste0("n=", n)),
position = position_dodge(0.9),
vjust = -0.5, size = 3) +
scale_fill_manual(values = c("Chargers" = "#0080C6",
"Rest of NFL" = "#888888")) +
scale_y_continuous(labels = scales::percent) +
labs(
title = "2nd & Short Conversion Rate: Chargers vs NFL (2024)",
subtitle = "Chargers underperformed league average on both run and pass",
x = "Play Type",
y = "Conversion Rate",
fill = ""
) +
theme_minimal()
# Show the cliff effect on 2nd down
cliff_data <- pbp |>
filter(
season_type == "REG",
down == 2,
ydstogo %in% 1:10,
play_type %in% c("run", "pass"),
!is.na(epa),
!is.na(ep),
yardline_100 %in% 45:55  # midfield only to control field position
)
cliff_data |>
group_by(ydstogo) |>
summarise(mean_ep = mean(ep, na.rm = TRUE)) |>
ggplot(aes(x = ydstogo, y = mean_ep)) +
geom_line(size = 1.2, color = "#0080C6") +
geom_point(size = 3, color = "#0080C6") +
geom_vline(xintercept = 3.5, linetype = "dashed",
color = "red", alpha = 0.7) +
annotate("text", x = 2, y = max(cliff_data$ep, na.rm = TRUE) * 0.8,
label = "Short\n(≤3)", color = "red", size = 3.5) +
annotate("text", x = 5, y = max(cliff_data$ep, na.rm = TRUE) * 0.8,
label = "Medium\n(4+)", color = "red", size = 3.5) +
labs(
title = "The Cliff Effect in nflfastR EP",
subtitle = "Expected Points by yards to go on 2nd down at midfield",
x = "Yards to Go",
y = "Expected Points",
caption = "Data: nflfastR | Red line shows short/medium boundary"
) +
scale_x_continuous(breaks = 1:10) +
theme_minimal()
pbp |>
filter(
season_type == "REG",
down == 2,
ydstogo <= 3,
play_type %in% c("run", "pass"),
!is.na(ep),
!is.na(score_differential)
) |>
mutate(
game_script = case_when(
score_differential >= 10  ~ "Winning Big",
score_differential <= -10 ~ "Losing Big",
TRUE                      ~ "Close Game"
)
) |>
group_by(game_script, yardline_100) |>
summarise(mean_ep = mean(ep), .groups = "drop") |>
ggplot(aes(x = yardline_100, y = mean_ep, color = game_script)) +
geom_smooth(se = FALSE) +
scale_x_reverse() +
labs(
title = "nflfastR EP is Nearly Identical Regardless of Score",
subtitle = "But winning by 10 vs losing by 10 changes everything strategically",
x = "Yards from Opponent End Zone",
y = "Expected Points",
color = "Game Script"
) +
theme_minimal()
pbp |> count(next_score_half)
pbp |> names() |> grep("score", x = _, value = TRUE)
