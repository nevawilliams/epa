library(nflreadr)
library(tidyverse)
pbp <- load_pbp(2016:2024) |>
filter(season_type == "REG",
!is.na(down),
!is.na(yardline_100),
!is.na(ydstogo))
# Define state buckets
pbp_states <- pbp |>
mutate(
dist_bucket = case_when(
ydstogo <= 3  ~ "short",
ydstogo <= 6  ~ "medium",
ydstogo <= 9  ~ "long",
TRUE          ~ "very_long"
),
field_bucket = case_when(
yardline_100 >= 80 ~ "own_red",
yardline_100 >= 50 ~ "own_terr",
yardline_100 >= 20 ~ "opp_terr",
TRUE               ~ "opp_red"
),
game_state = paste(down, dist_bucket, field_bucket, sep = "_")
)
# Check how many plays per state
pbp_states |>
count(game_state) |>
arrange(n)
pbp_states |>
count(game_state) |>
arrange(n) |>
write.csv("game_states.csv", row.names = FALSE)
pbp_states <- pbp_states |>
mutate(
game_state = case_when(
down == 1 ~ paste("1", field_bucket, sep = "_"),
TRUE      ~ game_state
)
)
pbp_states |>
count(game_state) |>
arrange(n) |>
print(n = Inf)
pbp_states |>
count(game_state) |>
arrange(n) |>
write.csv("game_states.csv", row.names = FALSE)
# First define absorbing states
pbp_states <- pbp_states |>
mutate(
absorbing = case_when(
touchdown == 1                          ~ "td",
field_goal_result == "made"             ~ "fg",
field_goal_result %in% c("missed","blocked") ~ "fg_miss",
interception == 1                       ~ "turnover",
fumble_lost == 1                        ~ "turnover",
punt_attempt == 1                       ~ "punt",
half_seconds_remaining == 0             ~ "end_half",
TRUE                                    ~ NA_character_
)
)
# Check absorbing state counts
pbp_states |>
count(absorbing) |>
arrange(desc(n))
pbp_states <- pbp_states |>
mutate(
absorbing = case_when(
touchdown == 1                               ~ "td",
field_goal_result == "made"                  ~ "fg",
field_goal_result %in% c("missed","blocked") ~ "fg_miss",
interception == 1                            ~ "turnover",
fumble_lost == 1                             ~ "turnover",
punt_attempt == 1                            ~ "punt",
half_seconds_remaining <= 5                  ~ "end_half",
TRUE                                         ~ NA_character_
)
)
)
pbp_states <- pbp_states |>
mutate(
absorbing = case_when(
touchdown == 1                               ~ "td",
field_goal_result == "made"                  ~ "fg",
field_goal_result %in% c("missed","blocked") ~ "fg_miss",
interception == 1                            ~ "turnover",
fumble_lost == 1                             ~ "turnover",
punt_attempt == 1                            ~ "punt",
half_seconds_remaining <= 5                  ~ "end_half",
TRUE                                         ~ NA_character_
)
)
# Check absorbing state counts
pbp_states |>
count(absorbing) |>
arrange(desc(n))
# Create from/to transition pairs
transitions <- pbp_states |>
arrange(game_id, play_id) |>
group_by(game_id) |>
mutate(
next_state = case_when(
!is.na(absorbing) ~ absorbing,
TRUE              ~ lead(game_state)
)
) |>
filter(!is.na(game_state), !is.na(next_state)) |>
ungroup()
# Check it
transitions |>
select(game_state, next_state) |>
head(20)
# Create from/to transition pairs
transitions <- pbp_states |>
arrange(game_id, play_id) |>
group_by(game_id) |>
mutate(
next_state = case_when(
!is.na(absorbing) ~ absorbing,
TRUE              ~ lead(game_state)
)
) |>
filter(!is.na(game_state), !is.na(next_state)) |>
ungroup()
# Check it
transitions |>
select(game_state, next_state) |>
head(200)
# Count transitions
transition_counts <- transitions |>
count(game_state, next_state)
# Convert to transition probability matrix
transition_matrix <- transition_counts |>
group_by(game_state) |>
mutate(prob = n / sum(n)) |>
ungroup() |>
select(game_state, next_state, prob) |>
pivot_wider(
names_from = next_state,
values_from = prob,
values_fill = 0
) |>
column_to_rownames("game_state")
# Quick sanity check - rows should sum to 1
rowSums(transition_matrix) |> round(2)
# After a punt - what EP does opponent get from where they receive it?
punt_ep <- pbp_states |>
filter(punt_attempt == 1, !is.na(kick_distance)) |>
mutate(
opponent_yardline = 100 - (yardline_100 - kick_distance),
opponent_yardline = pmax(pmin(opponent_yardline, 99), 1)
) |>
summarise(avg_opponent_yardline = mean(opponent_yardline, na.rm = TRUE))
# After a turnover - where does opponent get the ball?
turnover_ep <- pbp_states |>
filter(interception == 1 | fumble_lost == 1) |>
summarise(avg_yardline = mean(yardline_100, na.rm = TRUE))
# After a missed FG - opponent gets ball at spot
fg_miss_ep <- pbp_states |>
filter(field_goal_result %in% c("missed", "blocked")) |>
summarise(avg_yardline = mean(yardline_100, na.rm = TRUE))
# After a punt - what EP does opponent get from where they receive it?
