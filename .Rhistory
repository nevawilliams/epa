# All your transient states
states <- rownames(transition_matrix)
# Absorbing state fixed values
# Negative because opponent possession = your loss
absorbing_fixed <- c(
td       =  7.0,
fg       =  3.0,
fg_miss  = -0.7,   # opponent ~71 yards from end zone
punt     = -0.6,   # opponent ~80 yards from end zone
turnover = -2.0,   # opponent at midfield
end_half =  0.0
)
# Get only absorbing columns from transition matrix
absorbing_cols <- intersect(names(absorbing_fixed),
colnames(transition_matrix))
# Get only transient state columns
transient_cols <- intersect(states, colnames(transition_matrix))
# All your transient states
states <- rownames(transition_matrix)
# Absorbing state fixed values
# Negative because opponent possession = your loss
absorbing_fixed <- c(
td       =  7.0,
fg       =  3.0,
fg_miss  = -0.7,   # opponent ~71 yards from end zone
punt     = -0.6,   # opponent ~80 yards from end zone
turnover = -2.0,   # opponent at midfield
end_half =  0.0
)
# Get only absorbing columns from transition matrix
absorbing_cols <- intersect(names(absorbing_fixed),
colnames(transition_matrix))
# Get only transient state columns
transient_cols <- intersect(states, colnames(transition_matrix))
# A = transitions between transient states
A <- as.matrix(transition_matrix[states, transient_cols])
# B = transitions into absorbing states × their values
B <- as.matrix(transition_matrix[states, absorbing_cols]) %*%
absorbing_fixed[absorbing_cols]
# Solve: EP = A × EP + B
# Rearranges to: (I - A) × EP = B
I <- diag(nrow(A))
ep_markov <- solve(I - A, B)
ep_df_markov <- tibble(
game_state = states,
ep = as.numeric(ep_markov)
)
ep_df_markov |> arrange(desc(ep))
ep_df_markov |> arrange(desc(ep)) |> print(n = Inf)
ep_df_markov |> arrange(desc(ep)) |> print(n = Inf)
# Load built in ep values from nflfastR
comparison <- pbp_states |>
filter(!is.na(ep), !is.na(game_state)) |>
group_by(game_state) |>
summarise(nflfastr_ep = mean(ep, na.rm = TRUE)) |>
left_join(ep_df_markov, by = "game_state") |>
rename(markov_ep = ep) |>
mutate(difference = markov_ep - nflfastr_ep) |>
arrange(desc(abs(difference)))
comparison
library(ggplot2)
ggplot(comparison, aes(x = nflfastr_ep, y = markov_ep, label = game_state)) +
geom_point(color = "#0080C6", size = 3) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "red") +
geom_text(size = 2.5, vjust = -0.5, check_overlap = TRUE) +
labs(
title = "Markov EP vs nflfastR EP by Game State",
subtitle = "Points on dashed line = perfect agreement",
x = "nflfastR EP",
y = "Markov EP"
) +
theme_minimal()
# 2025 Chargers 2nd & short vs league average
second_short <- pbp |>
filter(
season == 2025,
season_type == "REG",
down == 2,
ydstogo <= 3,
play_type %in% c("run", "pass"),
!is.na(epa)
) |>
mutate(
is_chargers = if_else(posteam == "LAC", "Chargers", "League Average")
)
# Plot
ggplot(second_short, aes(x = play_type, y = epa, fill = is_chargers)) +
geom_boxplot(alpha = 0.7) +
facet_wrap(~is_chargers) +
scale_fill_manual(values = c("Chargers" = "#0080C6",
"League Average" = "#FFB81C")) +
labs(
title = "2nd & Short EPA: Chargers vs League Average (2025)",
subtitle = "Run vs Pass | Regular Season",
x = "Play Type",
y = "EPA",
caption = "Data: nflfastR"
) +
theme_minimal() +
theme(legend.position = "none")
